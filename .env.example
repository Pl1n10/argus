# argus — copy to .env and fill in. Used by docker-compose.yml.
# Generate a token with: openssl rand -hex 16

# Guards the dashboard and the job API (single-user MVP). Required.
ARGUS_ADMIN_TOKEN=changeme

# Public URL argus prints in copy-paste ingest URLs (and the dashboard login).
ARGUS_BASE_URL=http://localhost:8000

# Alert channels — leave blank to disable. Set what you use.
# ntfy topic URL, e.g. https://ntfy.sh/my-backups (or your self-hosted ntfy).
ARGUS_NTFY_URL=
# Telegram bot: both are needed for the channel to activate.
ARGUS_TELEGRAM_BOT_TOKEN=
ARGUS_TELEGRAM_CHAT_ID=
